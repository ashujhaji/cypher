# Discord application (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Comma-separated Discord role IDs allowed to file issues. Leave empty to allow everyone.
ALLOWED_ROLE_IDS=

# Fine-grained GitHub PAT with Issues: Read & Write on every repo listed in channels.json
GITHUB_TOKEN=

# Comma-separated labels applied to issues from channels with no per-channel
# "labels" override in channels.json
DEFAULT_LABELS=from-discord

# Discord channel ID -> {owner, repo, labels?} mapping, see channels.json.example.
# Every channel the bot is used in must have an entry here — there is no fallback repo.
CHANNEL_MAP_PATH=./channels.json

# Where the message-id -> issue-url dedupe map is persisted
STORE_PATH=./data/store.json

# Minimum seconds between issues filed by the same Discord user
COOLDOWN_SECONDS=10
